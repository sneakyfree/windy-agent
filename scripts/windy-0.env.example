# Windy 0 secrets — copy to ~/.windy/windy-0.env, chmod 600, then
# install the launchd service with scripts/install-windy-0-service.sh.
#
# Get values from ACCESS_LOCKBOX:
#   §2  Z.AI / ZhipuAI (GLM)
#   §5  Telegram Bots → Windy 0
#
# This file is sourced by launchd before exec'ing the bot, so anything
# you `export` here ends up in the agent's process environment. Do not
# commit a populated copy.

export ZAI_API_KEY='paste-zai-key-here'
export TELEGRAM_BOT_TOKEN='paste-telegram-bot-token-here'

# Optional overrides — uncomment if you want to deviate from windy-0.toml:
# export DEFAULT_MODEL='glm-4.7'
# export AGENT_OWNER_TELEGRAM_ID='8545546994'
