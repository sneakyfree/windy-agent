# ═══════════════════════════════════════════════════
# Windy Fly — Environment Variables
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your keys.
# Only OPENAI_API_KEY (or another LLM key) is required.

# ── LLM Providers (at least one required) ──────────
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
DEFAULT_MODEL=gpt-4o-mini

# Anthropic OAuth (uses your Claude Max subscription instead of API billing)
ANTHROPIC_OAUTH_ACCESS_TOKEN=
ANTHROPIC_OAUTH_REFRESH_TOKEN=
ANTHROPIC_OAUTH_EXPIRES_AT=

# Additional LLM Providers (all OpenAI-compatible)
GROK_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# ── Tool API Keys (all optional) ──────────────────
# Brave Search — free 2000 queries/month at brave.com/search/api
BRAVE_SEARCH_API_KEY=

# NewsAPI.org — free 100 requests/day (optional, RSS works without it)
NEWS_API_KEY=

# ── Owner (for hatch notifications) ───────────────
OWNER_PHONE=
OWNER_EMAIL=

# ── Database ──────────────────────────────────────
WINDYFLY_DB_PATH=data/windyfly.db
LOG_LEVEL=INFO

# ── Matrix / Windy Chat ──────────────────────────
MATRIX_HOMESERVER=https://chat.windyword.ai
MATRIX_BOT_USER=@windyfly:chat.windyword.ai
MATRIX_BOT_TOKEN=
MATRIX_BOT_PASSWORD=
SYNAPSE_REGISTRATION_SECRET=

# ── Windy Ecosystem ──────────────────────────────
# WINDY_PRO_URL is the account-server (identity hub); falls back to WINDY_API_URL.
WINDY_PRO_URL=
WINDY_API_URL=http://localhost:8098
WINDY_JWT=
# WINDY_IDENTITY_ID links the hatched agent's passport to a Windy identity.
# Leave blank for an offline/standalone hatch — link-back is skipped.
WINDY_IDENTITY_ID=
WINDYMAIL_API_URL=
WINDYMAIL_SERVICE_TOKEN=
WINDY_CLOUD_URL=
WINDY_CLOUD_TOKEN=
# Override the default dashboard URL used in hatch-announcement emails.
# Defaults to https://windyword.ai/app/fly; set this for internal betas
# or local development so the welcome email points to the right place.
WINDYFLY_DASHBOARD_URL=

# ── Trust gate ───────────────────────────────────
# Canonical contract: /Users/thewindstorm/eternitas/docs/trust-api.md
# ETERNITAS_URL is the base for GET /api/v1/trust/{passport}.
ETERNITAS_URL=http://localhost:8200
# Set true to bypass the live Trust API (useful in dev/test).
ETERNITAS_USE_MOCK=false
# Fail-open by default (trust service down → allow). Set to 1 in
# production to require a valid trust snapshot before every gated
# action (send_email, post_chat_message, run_command, upload_file, …).
WINDYFLY_TRUST_STRICT=
# Override the audit log path (default: data/audit/bot_key_usage.jsonl).
WINDYFLY_AUDIT_LOG=

# ── VPS / Dashboard ─────────────────────────────
# Set DASHBOARD_PASSWORD for VPS-deployed agents (not needed locally)
DASHBOARD_PASSWORD=

# ── Messaging Channels (all optional) ────────────
# Set any of these to enable that channel.

# Telegram (@BotFather → /newbot → copy token)
TELEGRAM_BOT_TOKEN=

# Discord (discord.com/developers → Bot → Token)
DISCORD_BOT_TOKEN=

# Slack (api.slack.com/apps → Socket Mode)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# WhatsApp (via Twilio)
TWILIO_WHATSAPP_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Signal (requires signal-cli-rest-api Docker container)
SIGNAL_API_URL=http://localhost:8080
SIGNAL_PHONE_NUMBER=

# Microsoft Teams
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# IRC
IRC_SERVER=
IRC_PORT=6667
IRC_CHANNEL=
IRC_NICKNAME=windyfly
