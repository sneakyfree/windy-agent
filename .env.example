# LLM Providers
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
DEFAULT_MODEL=gpt-4o-mini

# Anthropic OAuth (uses your Claude Max subscription instead of API billing)
# Set these to use OAuth instead of ANTHROPIC_API_KEY
ANTHROPIC_OAUTH_ACCESS_TOKEN=
ANTHROPIC_OAUTH_REFRESH_TOKEN=
ANTHROPIC_OAUTH_EXPIRES_AT=

# Additional LLM Providers (all OpenAI-compatible — just set the key)
GROK_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# Database
WINDYFLY_DB_PATH=data/windyfly.db

# Logging
LOG_LEVEL=INFO

# Matrix / Windy Chat
MATRIX_HOMESERVER=https://chat.windypro.com
MATRIX_BOT_USER=@windyfly:chat.windypro.com
MATRIX_BOT_TOKEN=
MATRIX_BOT_PASSWORD=

# Windy Pro API
WINDY_API_URL=http://localhost:8098
WINDY_JWT=

# Windy Mail provisioning (used during hatch)
WINDYMAIL_API_URL=http://localhost:8200
WINDYMAIL_SERVICE_TOKEN=

# ── Messaging Channels ──────────────────
# Set any of these to enable that channel. Windy Fly auto-detects.

# Telegram (@BotFather → /newbot → copy token)
TELEGRAM_BOT_TOKEN=

# Discord (discord.com/developers → Bot → Token)
DISCORD_BOT_TOKEN=

# Slack (api.slack.com/apps → Socket Mode)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# WhatsApp (via Twilio — twilio.com → WhatsApp Sandbox)
TWILIO_WHATSAPP_NUMBER=

# Signal (requires signal-cli-rest-api Docker container)
SIGNAL_API_URL=http://localhost:8080
SIGNAL_PHONE_NUMBER=

# Microsoft Teams (dev.teams.microsoft.com)
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# IRC (no credentials needed)
IRC_SERVER=
IRC_PORT=6667
IRC_CHANNEL=
IRC_NICKNAME=windyfly
