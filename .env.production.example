# ============================================================================
# Windy Fly — PRODUCTION environment template
# ============================================================================
#
# Copy to /etc/windyfly/production.env (chmod 0600, owned by the windyfly
# user) and fill in real values. This file is loaded by the systemd unit
# via EnvironmentFile=.
#
# Legend:
#   [REQUIRED]  agent won't boot / won't be secure without it
#   [PROD]      required in production, optional in dev
#   [OPT]       optional; pick what you use
#
# Every entry here is read by src/windyfly or gateway/src — see DEPLOY.md §3
# and deploy/aws/FLY_DEPLOYMENT.md for the architectural context.
# ============================================================================


# ── Agent identity ──────────────────────────────────────────────────────────

# Display name shown on the dashboard and in the birth certificate.
# [OPT]
WINDYFLY_AGENT_NAME=

# Where the agent's SQLite + recovery files live. Default: ./data/windyfly.db
# Always set explicitly on the VPS so systemd's ProtectSystem=strict has the
# right ReadWritePaths.
# [PROD]
WINDYFLY_DB_PATH=/opt/windyfly/data/windyfly.db

# Directory for audit log files (bot_key_usage.jsonl, webhook_receipts.jsonl).
# [PROD]
WINDYFLY_HOME=/opt/windyfly


# ── LLM provider keys ───────────────────────────────────────────────────────

# Only ONE of these is strictly required — DEFAULT_MODEL below picks which.
# In production-with-Pro the broker populates these at hatch-time and
# again at each rotation; in BYOK mode the operator fills in one by hand.
# [REQUIRED — at least one]
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
BRAVE_SEARCH_API_KEY=
NEWS_API_KEY=

# Anthropic Claude-code OAuth (alternative to ANTHROPIC_API_KEY for
# per-user Claude access). Leave blank unless wired up.
# [OPT]
ANTHROPIC_OAUTH_ACCESS_TOKEN=
ANTHROPIC_OAUTH_REFRESH_TOKEN=
ANTHROPIC_OAUTH_EXPIRES_AT=

# Pinned model. Must be a model the active provider supports.
# Example: "claude-3-5-sonnet-latest" or "gpt-4o-mini".
# [REQUIRED]
DEFAULT_MODEL=claude-3-5-sonnet-latest

# Sampling knobs (also settable via windyfly.toml; env overrides).
# [OPT]
LLM_TEMPERATURE=0.7
MAX_CONTEXT_TOKENS=8000
DAILY_BUDGET_USD=5.0


# ── Windy Pro broker (managed credentials) ──────────────────────────────────

# The Pro account this agent is paired with. Can also live in
# ~/.windypro/config.json — env var wins.
# [OPT — set one of env / ~/.windypro/config.json]
WINDY_IDENTITY_ID=

# Hosted Pro API — JWKS + broker endpoint live here. In prod: windyword.ai.
# [PROD]
WINDY_PRO_URL=https://windyword.ai
WINDY_API_URL=https://windyword.ai

# Shared HMAC secret between this agent and the Pro instance. Signs
# broker requests (X-Windy-Signature: sha256=...). 32+ bytes of
# crypto-random, generated during VPS provisioning.
# [REQUIRED — with Pro broker]
WINDY_BROKER_SIGNING_SECRET=

# Pin the broker-issued credential to a single provider env var. If
# unset, the broker token is written to every provider key field so
# whichever provider DEFAULT_MODEL selects works.
# [OPT]
WINDY_BROKER_PROVIDER=

# The broker token itself — populated automatically by `windy hatch`
# or the remote /hatch/remote flow. Do NOT set by hand; if you do,
# rotation will overwrite it.
# [OPT]
WINDY_BROKER_TOKEN=

# Legacy alias kept for transition; prefer WINDY_BROKER_SIGNING_SECRET.
# [OPT]
WINDY_PRO_SIGNING_SECRET=

# Owner JWT from Pro — used before wk_ mint and as a fallback after
# rotation failures.
# [OPT]
WINDY_JWT=

# Owner identity overrides — normally derived from WINDY_JWT.
# [OPT]
WINDY_OWNER_ID=
WINDY_OWNER_NAME=


# ── Eternitas (identity + trust) ────────────────────────────────────────────

# Canonical URL. Both ETERNITAS_URL and ETERNITAS_API_URL are read
# by different call sites; set both to the same value in prod.
# [PROD]
ETERNITAS_URL=https://eternitas.ai
ETERNITAS_API_URL=https://eternitas.ai

# Issued on first hatch; the agent persists it back here after the
# passport is minted. On a fresh VPS, leave blank — hatch will fill.
# [OPT]
ETERNITAS_PASSPORT=

# Shared secret for inbound trust.changed webhook HMAC verification.
# Eternitas signs; we verify. Must match the secret registered with
# Eternitas's webhook-subscription API.
# [REQUIRED — if receiving trust webhooks]
ETERNITAS_WEBHOOK_SECRET=

# Admin-only (rarely set). Used by `windy passport reissue` and
# similar ops commands; leave blank on a normal VPS.
# [OPT]
ETERNITAS_ADMIN_TOKEN=
ETERNITAS_OPERATOR_KEY=

# Dev-only mock mode. Never true in production.
# [OPT]
ETERNITAS_USE_MOCK=false

# Enforce clearance-gated actions in strict mode. In production this
# should be TRUE so an unknown trust band fails closed. Only flip
# to FALSE during a documented Eternitas outage (see DEPLOY.md §5.1).
# [PROD]
WINDYFLY_TRUST_STRICT=true


# ── Windy Chat (Matrix) ─────────────────────────────────────────────────────

# Homeserver URL — in prod: chat.windychat.ai.
# [PROD]
MATRIX_HOMESERVER=https://chat.windychat.ai

# Bot MXID — the agent's Matrix identity. Shape:
#   @<agent-slug>:chat.windychat.ai
# Filled in by `windy hatch` provisioning; can be overridden for
# legacy accounts.
# [OPT]
MATRIX_BOT_USER=

# ONE of the following, not both. TOKEN is preferred — password
# requires a login round-trip per restart.
# [OPT — at least one if Matrix is used]
MATRIX_BOT_TOKEN=
MATRIX_BOT_PASSWORD=

# Admin endpoint + shared secret for auto-registering new bots.
# Required only when hatching fresh agents against this homeserver.
# [OPT]
SYNAPSE_ADMIN_URL=
SYNAPSE_REGISTRATION_SECRET=


# ── Windy Mail ──────────────────────────────────────────────────────────────

# JMAP API URL. In prod: mail.windymail.ai.
# [PROD]
WINDYMAIL_API_URL=https://mail.windymail.ai

# Service-level token used during `windy hatch` to provision a new
# inbox. Scope: inbox-create only; the agent gets a per-inbox token
# in return.
# [REQUIRED — with fresh hatches]
WINDYMAIL_PROVISION_SERVICE_TOKEN=

# Service / JMAP tokens for outbound sends after hatch. Populated
# after inbox provisioning; do not set by hand unless migrating.
# [OPT]
WINDYMAIL_SERVICE_TOKEN=
WINDYMAIL_JMAP_TOKEN=
WINDYMAIL_EMAIL=


# ── Windy Cloud ─────────────────────────────────────────────────────────────

# Cloud API URL. In prod: cloud.windycloud.com.
# [PROD]
WINDY_CLOUD_URL=https://cloud.windycloud.com

# Token used by `windy cloud vps-deploy` and quota-allocation calls
# during hatch. Minted from the Pro console.
# [PROD]
WINDY_CLOUD_TOKEN=


# ── Phone (SMS / WhatsApp) ──────────────────────────────────────────────────

# Twilio credentials. Required if the agent should send the
# "Hi, I just hatched" SMS to the owner.
# [OPT]
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# SendGrid Inbound Parse — for agent email ingestion (outbound still
# goes via Windy Mail's JMAP).
# [OPT]
SENDGRID_API_KEY=


# ── Channel adapters (optional — set only what you use) ─────────────────────

# Telegram
# [OPT]
TELEGRAM_BOT_TOKEN=

# Slack
# [OPT]
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Discord
# [OPT]
DISCORD_BOT_TOKEN=

# Signal (via signal-cli-rest-api)
# [OPT]
SIGNAL_API_URL=
SIGNAL_PHONE_NUMBER=

# Microsoft Teams
# [OPT]
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# IRC
# [OPT]
IRC_SERVER=
IRC_PORT=
IRC_NICKNAME=
IRC_CHANNEL=


# ── Owner reach-out (for the hatch ceremony only) ───────────────────────────

# Used by /hatch/remote to address the "Hi, I just hatched" SMS /
# email to the right human. Cleared after the first run.
# [OPT]
OWNER_EMAIL=
OWNER_PHONE=

# Shown on `windy status` once the hatch SMS/Email has been sent.
# [OPT]
AGENT_EMAIL=
AGENT_PHONE=


# ── Observability ───────────────────────────────────────────────────────────

# Python log level (DEBUG, INFO, WARNING, ERROR).
# [PROD]
LOG_LEVEL=INFO

# Sentry (optional — gateway + brain both pick up SENTRY_DSN if set).
# [OPT]
SENTRY_DSN=
SENTRY_ENV=production

# Audit log file path (JSONL of bot-key + webhook activity).
# [PROD]
WINDYFLY_AUDIT_LOG=/var/log/windyfly/audit.jsonl


# ── Gateway (Bun) ───────────────────────────────────────────────────────────

# Marks the gateway as running in production — enables fail-closed
# behaviours (empty DASHBOARD_PASSWORD becomes a hard boot error,
# CORS allowlist is enforced strictly).
# [REQUIRED — in production]
WINDYFLY_ENV=production

# Dashboard password — REQUIRED when WINDYFLY_ENV=production. 24+
# random characters (crypto-random). Rotate quarterly.
# [REQUIRED — in production]
DASHBOARD_PASSWORD=

# IPC between the Python brain and the Bun gateway. Defaults to a
# UNIX domain socket in /tmp. Override only for tight-security
# deployments that can't write to /tmp.
# [OPT]
WINDYFLY_IPC_MODE=uds
WINDYFLY_IPC_PATH=/tmp/windyfly.sock
WINDYFLY_IPC_HOST=127.0.0.1
WINDYFLY_IPC_PORT=4001


# ── Integrations ────────────────────────────────────────────────────────────

# Google Calendar (optional integration). OAuth credentials JSON
# file path + token file path.
# [OPT]
GOOGLE_CALENDAR_CREDENTIALS=
GOOGLE_CALENDAR_TOKEN=

# Preferred UX locale + timezone + editor for CLI interactions.
# [OPT]
PREFERRED_LANGUAGE=en
TIMEZONE=UTC
OUTPUT_THEME=dark
EDITOR=vim

# Brand override — flip to "hifly" only in the HiFly fork.
# [OPT]
HIFLY_BRAND=windyfly
